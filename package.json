{
  "name": "legal-transcription-tool",
  "version": "1.0.0",
  "description": "面向律师事务所和合规部门的桌面端会议取证转写工具",
  "main": "dist-electron/main/index.js",
  "author": "LegalTech",
  "license": "MIT",
  "private": true,
  "keywords": [
    "electron",
    "react",
    "typescript",
    "legal",
    "transcription"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:unpack": "tsc && vite build && electron-builder --dir",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0",
    "lucide-react": "^0.344.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.legaltech.transcription",
    "productName": "会议取证转写工具",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
